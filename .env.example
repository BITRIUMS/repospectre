# ══════════════════════════════════════════════════
#  RepoSpectre — Environment Variables
#  Copy this file to .env.local for local development
#  Add these to Vercel Dashboard → Project → Settings → Environment Variables
# ══════════════════════════════════════════════════

# Nous Research API Key (REQUIRED)
# Get from: portal.nousresearch.com/api-keys
# This key is stored ONLY on the server — never exposed to the browser
NOUS_API_KEY=your-nous-api-key-here

# GitHub Personal Access Token (OPTIONAL but recommended)
# Raises GitHub API rate limit from 60 → 5000 req/hour
# Get from: github.com/settings/tokens (scope: public_repo)
GITHUB_TOKEN=ghp_optional-github-token-here
